# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Google Books API ──────────────────────────────────────────────────────────
# Create / manage at: https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_BOOKS_API_KEY=

# ── Groq ─────────────────────────────────────────────────────────────────────
# Create at: https://console.groq.com → API Keys
VITE_GROQ_API_KEY=
